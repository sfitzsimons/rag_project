import os
import csv
import yt_dlp
import whisper
import time
import re
import json

from datetime import datetime
from itertools import product
from datasets import Dataset

from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_chroma import Chroma

from langchain_cohere import CohereEmbeddings
from langchain_openai import ChatOpenAI

from langchain_core.runnables import RunnableParallel, RunnablePassthrough, RunnableLambda
from langchain_core.prompts import PromptTemplate

from ragas import evaluate
from ragas.metrics import faithfulness



# CONFIG


CHUNK_SIZES = [1000, 1500, 2000, 2500]
CHUNK_OVERLAPS = [100, 200, 300]
K_VALUES = [2, 4, 6, 8]


CSV_FILE = "test.csv"
AUDIO_FILE = "audio.mp3"



# PROMPTS


ANSWER_PROMPT = PromptTemplate.from_template("""
You are a precise QA system.

Rules:
- Use ONLY the provided context
- If not found, say "Not found in context"
- Be concise

Context:
{context}

Question:
{query}

Answer:
""")


CONTEXT_EVAL_PROMPT = PromptTemplate.from_template("""
You are evaluating retrieval quality.

Score how relevant the retrieved context is for answering the question.

0.0 = irrelevant
0.5 = partially relevant
1.0 = highly relevant

Return ONLY JSON.

Question:
{query}

Context:
{context}
""")



# UTILITIES 


def clean_chunks(chunks):
    
    cleaned = []
    for c in chunks:
        if c is None:
            continue
        if not isinstance(c, str):
            c = str(c)
        c = c.strip()
        if c:
            cleaned.append(c)
    return cleaned


def count_words(text):     
    return len(text.split())


def count_retrieved_words(docs):
    return sum(count_words(d.page_content) for d in docs)



# CUSTOM SCORE PARSER
# extract JSON from model output

class ScoreParser:
    def parse(self, text: str) -> float:
        try:
            match = re.search(r"\{.*\}", text, re.DOTALL)
            if match:
                data = json.loads(match.group())
                if "score" in data:
                    return float(data["score"])
        except:
            pass

        match = re.search(r"(0(\.\d+)?|1(\.0+)?)", text)
        if match:
            return float(match.group(1))

        return 0.0


parser = ScoreParser()


def context_score(llm, query, docs):
    context = "\n\n".join(d.page_content for d in docs)

    prompt = CONTEXT_EVAL_PROMPT.format(
        query=query,
        context=context
    )

    return parser.parse(llm.invoke(prompt).content)



# CSV LOGGING


def init_csv():
    if not os.path.exists(CSV_FILE):
        with open(CSV_FILE, "w", newline="", encoding="utf-8") as f:
            csv.writer(f).writerow([
                "url", "model", "chunk_size", "chunk_overlap", "k",
                "query", "answer",
                "faithfulness_score", "context_score",
                "words", "length",
                "latency", "timestamp"
            ])


def log_row(url, model, cs, co, k, query, answer,
            faith, ctx, words, length, latency):

    with open(CSV_FILE, "a", newline="", encoding="utf-8") as f:
        csv.writer(f).writerow([
            url, model, cs, co, k,
            query, answer,
            faith, ctx,
            words, length,
            latency,
            datetime.now().isoformat()
        ])



# RAG CHAIN


def build_rag_chain(retriever, llm):

    return (
        RunnableParallel({
            "docs": retriever,
            "query": RunnablePassthrough()
        })

        | RunnableLambda(lambda x: {
            "context": "\n\n".join(d.page_content for d in x["docs"]),
            "query": x["query"]
        })

        | ANSWER_PROMPT
        | llm
    )



# RAGAS EVAL


def ragas_faithfulness(query, answer, docs, llm):
    dataset = Dataset.from_dict({
        "question": [query],
        "answer": [answer],
        "contexts": [[d.page_content for d in docs]]
    })

    result = evaluate(dataset, metrics=[faithfulness], llm=llm)
    return float(result["faithfulness"][0])



# EXPERIMENT LOOP


def run_experiments(url, text, queries):

    llm = ChatOpenAI(model="gpt-4o-mini", temperature=0)

   
    embeddings = CohereEmbeddings(model="embed-english-v3.0")
    # grid search through all possible combinations
    for chunk_size, chunk_overlap, k in product(
        CHUNK_SIZES, CHUNK_OVERLAPS, K_VALUES
    ):

        print(f"\n=== chunk={chunk_size}, overlap={chunk_overlap}, k={k} ===")

        splitter = RecursiveCharacterTextSplitter(
            chunk_size=chunk_size,
            chunk_overlap=chunk_overlap
        )

        raw_chunks = splitter.split_text(text)

     
        chunks = clean_chunks(raw_chunks)

        
        vectorstore = Chroma.from_texts(
            texts=chunks,
            embedding=embeddings
        )

        retriever = vectorstore.as_retriever(search_kwargs={"k": k})

        rag_chain = build_rag_chain(retriever, llm)

        for query in queries:

            start = time.time()

            
            result = rag_chain.invoke(query)

            latency = time.time() - start

            docs = retriever.invoke(query)

            faith = ragas_faithfulness(query, result.content, docs, llm)
            ctx = context_score(llm, query, docs)

            words = count_retrieved_words(docs)
            length = len(result.content)

            log_row(
                url, "gpt-4o-mini",
                chunk_size, chunk_overlap, k,
                query, result.content,
                faith, ctx,
                words, length, latency
            )

            print(f"Faith={faith:.3f} | Context={ctx:.3f} | Time={latency:.2f}s")



# MAIN


if __name__ == "__main__":

    init_csv()

    url = input("Enter YouTube URL: ")

    # download audio
    ydl_opts = {
        "format": "bestaudio/best",
        "outtmpl": "audio.%(ext)s",
        "postprocessors": [{
            "key": "FFmpegExtractAudio",
            "preferredcodec": "mp3",
            "preferredquality": "192",
        }],
    }

    with yt_dlp.YoutubeDL(ydl_opts) as ydl:
        ydl.extract_info(url, download=True)

    # whisper transcription
    model = whisper.load_model("base")
    text = model.transcribe(AUDIO_FILE)["text"]

    queries = [
        
        "What is this video about?",
        "Summarize the key points",
        "What are the main arguments?",
        "What is the most quotable line?",
        "Give a one to two sentence summary of the document",
        "What is the speaker’s central claim?"
    ]

    run_experiments(url, text, queries)
